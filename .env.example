# Anthropic API (JD 분석 / 이력서 매칭에 사용)
ANTHROPIC_API_KEY=

# 사용할 모델 (예: claude-opus-4-8, claude-sonnet-5, claude-haiku-4-5)
ANTHROPIC_MODEL=claude-opus-4-8

# SQLite DB 파일 경로
DATABASE_URL=sqlite:///data/career_sniper.db

# 참고: 각 회사 채용 페이지가 실제로 쓰는 ATS(Greenhouse/Lever/Ashby/Workday)의
# API 엔드포인트는 회사마다 필요한 파라미터가 달라서(예: Workday는 URL 하나가 아니라
# tenant/host/site 조합이 필요) crawlers/*.py에 상수로 하드코딩되어 있습니다.
# ATS가 바뀌면 해당 크롤러 파일의 상수를 직접 수정하세요.

# 크롤링 시 검색할 직무 키워드 (쉼표로 구분)
JOB_SEARCH_KEYWORDS=Software Engineer,Machine Learning Engineer,Product Manager

# Playwright 설정
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# 크롤링 요청 간 지연 시간(초) - 과도한 요청 방지
CRAWL_DELAY_SECONDS=2

# 내 이력서 파일 경로 (resume/ 폴더 내 위치, PDF 또는 DOCX)
RESUME_FILE_PATH=resume/my_resume.pdf

# Streamlit 서버 포트
STREAMLIT_SERVER_PORT=8501
