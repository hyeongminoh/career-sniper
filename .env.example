# Anthropic API (JD 분석 / 이력서 매칭에 사용)
ANTHROPIC_API_KEY=

# 사용할 모델 (예: claude-sonnet-5, claude-opus-4-8, claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-sonnet-5

# SQLite DB 파일 경로
DATABASE_URL=sqlite:///data/career_sniper.db

# 크롤링 대상 회사 채용 페이지 URL
ANTHROPIC_CAREERS_URL=https://www.anthropic.com/jobs
GOOGLE_CAREERS_URL=https://www.google.com/about/careers/applications/jobs/results
SALESFORCE_CAREERS_URL=https://careers.salesforce.com/en/jobs/
PALANTIR_CAREERS_URL=https://www.palantir.com/careers/
OPENAI_CAREERS_URL=https://openai.com/careers/

# 크롤링 시 검색할 직무 키워드 (쉼표로 구분)
JOB_SEARCH_KEYWORDS=Software Engineer,Machine Learning Engineer,Product Manager

# Playwright 설정
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# 크롤링 요청 간 지연 시간(초) - 과도한 요청 방지
CRAWL_DELAY_SECONDS=2

# 내 이력서 파일 경로 (resume/ 폴더 내 위치, PDF 또는 DOCX)
RESUME_FILE_PATH=resume/my_resume.pdf

# Streamlit 서버 포트
STREAMLIT_SERVER_PORT=8501
